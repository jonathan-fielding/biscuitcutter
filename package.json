{
  "name": "biscuitcutter",
  "version": "0.0.6",
  "description": "A command-line utility that creates projects from project templates, e.g. creating a TypeScript package project from a project template.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "biscuitcutter": "dist/cli/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/cli/cli.js",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src tests --ext .ts",
    "lint:fix": "eslint src tests --ext .ts --fix",
    "prepublishOnly": "npm run build && npm test",
    "changeset": "npx @changesets/cli"
  },
  "keywords": [
    "biscuitcutter",
    "cookiecutter",
    "template",
    "scaffolding",
    "project-template",
    "generator",
    "boilerplate",
    "nunjucks"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/biscuitcutter/biscuitcutter.git"
  },
  "homepage": "https://github.com/biscuitcutter/biscuitcutter#readme",
  "bugs": {
    "url": "https://github.com/biscuitcutter/biscuitcutter/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "fs-extra": "^11.3.4",
    "inquirer": "^12.11.1",
    "istextorbinary": "^9.5.0",
    "nunjucks": "^3.2.4",
    "slugify": "^1.6.6",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^25.3.5",
    "@types/nunjucks": "^3.2.6",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.1",
    "eslint-config-airbnb-typescript": "^18.0.0",
    "eslint-plugin-import": "^2.32.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
